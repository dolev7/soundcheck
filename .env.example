# Copy this file to `.env.local` and fill in your Spotify app's Client ID.
# `.env.local` is gitignored — your Client ID stays out of version control.
#
# Create an app at https://developer.spotify.com/dashboard, then add this exact
# Redirect URI in the app settings (Spotify no longer accepts "localhost" for
# loopback — it must be the 127.0.0.1 loopback IP):
#
#   http://127.0.0.1:5173/callback
#
# The Client ID is NOT a secret in a PKCE flow — it is safe to ship in the
# browser bundle. There is intentionally no client secret here.

VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
