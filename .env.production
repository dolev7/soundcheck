# Committed on purpose. In a PKCE flow the Client ID is PUBLIC (it ships in the
# browser bundle; there is no client secret), so it's safe in version control.
# The redirect URI is derived at runtime from the deployed origin + base path,
# so it isn't set here.
VITE_SPOTIFY_CLIENT_ID=011ca5b020e74f7480a9c1d9a1e1f15a
