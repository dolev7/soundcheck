{
  "name": "soundcheck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Artist-first Spotify music guessing game (solo/async, Premium-gated).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build --base=/soundcheck/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/spotify-web-playback-sdk": "^0.1.19",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
